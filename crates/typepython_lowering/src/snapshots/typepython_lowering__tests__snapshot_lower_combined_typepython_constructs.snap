from typing import TypeAlias
from typing import Protocol
from dataclasses import dataclass
from typing import overload
UserId: TypeAlias = int

class Closable(Protocol):
    def close(self) -> None: ...

@dataclass
class Point:
    x: float
    y: float

class Expr:  # tpy:sealed
    ...

@overload
def parse(x: str) -> int: ...

def helper() -> int:
    return 1
