class Any:
    pass

class Iterator:
    def __next__(self) -> Any: ...

class Awaitable:
    def __await__(self) -> Iterator: ...

class AsyncIterator:
    def __anext__(self) -> Awaitable: ...

class Sized:
    def __len__(self) -> int: ...

class Iterable:
    def __iter__(self) -> Iterator: ...

class Sequence:
    def __getitem__(self, index: int) -> Any: ...
    def __iter__(self) -> Iterator: ...
    def count(self, item: object) -> int: ...
    def index(self, item: object) -> int: ...

class Mapping:
    def __getitem__(self, key: Any) -> Any: ...
    def __iter__(self) -> Iterator: ...
    def keys(self) -> Any: ...
    def values(self) -> Any: ...
    def items(self) -> Any: ...
    def get(self, key: Any, default) -> Any: ...

class Callable:
    def __call__(self) -> Any: ...

class AsyncIterable:
    def __aiter__(self) -> AsyncIterator: ...

class AsyncGenerator:
    def asend(self, value: Any) -> Awaitable: ...
    def athrow(self, typ: Any, val: Any, tb: Any) -> Awaitable: ...
    def aclose(self) -> Awaitable: ...
